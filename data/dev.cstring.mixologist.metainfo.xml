	<name>Mixologist</name>
	<summary>Configurable audio mixing</summary>

	<metadata_license>MIT</metadata_license>
	<project_license>MIT-0</project_license>

	<description>
		<p>
			Mixologist is a simple but powerful audio mixing tool. Select the programs you would like
			and balance between those and the rest of the system. Fade between your voice call and
			favorite game without missing a beat.
		</p>
		<p>Features:</p>
		<ul>
			<li>Automatic routing of program audio</li>
			<li>Keyboard control via global shortcuts</li>
			<li>Seamless handling of audio device switches</li>
			<li>Rich program matching</li>
			<li>Socket control for scripting integrations</li>
		</ul>
		<p>
			Mixologist has a hard requirement on PipeWire and does not support PulseAudio.
		</p>
	</description>

	<launchable type="desktop-id">dev.cstring.mixologist.desktop</launchable>
	<url type="homepage">https://git.cstring.dev/haydengray/mixologist</url>
  <content_rating type="oars-1.1" />

